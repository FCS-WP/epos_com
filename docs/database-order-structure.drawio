  <diagram id="order-status" name="2. Order Status Flow">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Order Status Flow &amp; Transitions" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="35" as="geometry" />
        </mxCell>

        <!-- Pending -->
        <mxCell id="pending" value="&lt;b&gt;pending&lt;/b&gt;&lt;br&gt;Order created,&lt;br&gt;awaiting payment" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- On-hold -->
        <mxCell id="onhold" value="&lt;b&gt;on-hold&lt;/b&gt;&lt;br&gt;2C2P respCode 0001&lt;br&gt;(payment pending)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="340" y="100" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="0001" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=10;fontColor=#E65100;" edge="1" source="pending" target="onhold" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Processing -->
        <mxCell id="processing" value="&lt;b&gt;processing&lt;/b&gt;&lt;br&gt;payment_complete()&lt;br&gt;2C2P respCode 0000" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="600" y="90" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="0000" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=10;fontColor=#1976D2;strokeWidth=2;" edge="1" source="pending" target="processing" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="80" />
              <mxPoint x="700" y="80" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e3" value="retry success" style="edgeStyle=orthogonalEdgeStyle;fontStyle=2;fontSize=10;fontColor=#1976D2;" edge="1" source="onhold" target="processing" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Completed -->
        <mxCell id="completed" value="&lt;b&gt;completed&lt;/b&gt;&lt;br&gt;Order fulfilled" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="admin action" style="edgeStyle=orthogonalEdgeStyle;fontStyle=2;fontSize=10;fontColor=#388E3C;" edge="1" source="processing" target="completed" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Failed -->
        <mxCell id="failed" value="&lt;b&gt;failed&lt;/b&gt;&lt;br&gt;3 retries exhausted&lt;br&gt;or payment error" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="340" y="230" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="max retries" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fontSize=10;fontColor=#b85450;" edge="1" source="onhold" target="failed" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5b" value="payment error" style="edgeStyle=orthogonalEdgeStyle;fontStyle=2;fontSize=10;fontColor=#b85450;" edge="1" source="pending" target="failed" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="257" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Cancelled -->
        <mxCell id="cancelled" value="&lt;b&gt;cancelled&lt;/b&gt;&lt;br&gt;Admin or customer&lt;br&gt;cancelled" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#ECEFF1;strokeColor=#455A64;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="230" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="admin" style="edgeStyle=orthogonalEdgeStyle;fontStyle=2;fontSize=10;fontColor=#455A64;" edge="1" source="processing" target="cancelled" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Refunded -->
        <mxCell id="refunded" value="&lt;b&gt;refunded&lt;/b&gt;&lt;br&gt;Full/partial refund" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="860" y="230" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="admin" style="edgeStyle=orthogonalEdgeStyle;fontStyle=2;fontSize=10;fontColor=#7B1FA2;" edge="1" source="completed" target="refunded" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Trash -->
        <mxCell id="trash" value="&lt;b&gt;trash&lt;/b&gt;&lt;br&gt;(soft delete via&lt;br&gt;move_to_trash API)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#ECEFF1;strokeColor=#9E9E9E;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="600" y="350" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="dashed=1;strokeColor=#9E9E9E;" edge="1" source="cancelled" target="trash" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="dashed=1;strokeColor=#9E9E9E;" edge="1" source="failed" target="trash" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Triggers box -->
        <mxCell id="triggers" value="&lt;b&gt;On status → processing:&lt;/b&gt;&lt;br&gt;• HubSpot: Update contact (PAID) + Create deal&lt;br&gt;• Facebook CAPI: Purchase event (server-side)&lt;br&gt;• WooCommerce: New Order email (admin)&lt;br&gt;• WooCommerce: Processing email (customer)" style="shape=note;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;size=14;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="330" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e_triggers" style="dashed=1;strokeColor=#d6b656;" edge="1" source="processing" target="triggers" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1070" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Bulk action note -->
        <mxCell id="bulk_note" value="&lt;b&gt;Admin Bulk Actions (zippy-core API):&lt;/b&gt;&lt;br&gt;bulk-action-update-order-status → change status of multiple orders&lt;br&gt;move-to-trash → soft delete selected orders" style="shape=note;whiteSpace=wrap;html=1;fontSize=10;fillColor=#ECEFF1;strokeColor=#455A64;size=12;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
