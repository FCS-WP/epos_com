        <!-- Step 1: Generate JWT -->
        <mxCell id="tc1" value="Generate JWT payload&lt;br&gt;&lt;b&gt;(merchantID, invoiceNo, amount,&lt;br&gt;currencyCode, HS256 signed)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFE0B2;strokeColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="500" y="1235" width="280" height="55" as="geometry" />
        </mxCell>

        <!-- Step 2: Request Token -->
        <mxCell id="tc2" value="POST /paymentToken&lt;br&gt;&lt;b&gt;Request payment token from 2C2P&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFE0B2;strokeColor=#E65100;" vertex="1" parent="1">
